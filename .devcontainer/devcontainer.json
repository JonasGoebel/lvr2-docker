{
  "name": "lvr2-docker",
  "build": {
    "context": "..",
    "dockerfile": "../Dockerfile"
  },
  "runArgs": [
    "--gpus", "all",
    "--runtime=nvidia"
  ],
  "containerEnv": {
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "all"
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  }
}
